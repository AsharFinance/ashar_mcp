{
  "name": "ashar-mcp-server",
  "version": "2.0.0",
  "description": "MCP server for Ashar Finance API — depositos, conversoes, saques, composicao de carteiras (Notus + Management + CaaS), com retry, tracing e diagnosticos",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "ashar-mcp": "dist/index.js"
  },
  "scripts": {
    "start": "node dist/index.js",
    "build": "tsc",
    "clean": "rm -rf dist",
    "prebuild": "npm run clean",
    "prestart": "npm run build",
    "dev": "tsx watch src/index.ts",
    "dev:debug": "ASHAR_DEBUG=true tsx watch src/index.ts"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.6.1",
    "express": "^4.21.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "keywords": [
    "mcp",
    "ashar",
    "finance",
    "pix",
    "crypto",
    "diagnostics",
    "retry"
  ],
  "license": "UNLICENSED",
  "private": true
}
