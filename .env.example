# Ashar MCP Server - Configuracao

# URL da API Ashar Management (padrao: https://api.ashar.finance)
ASHAR_API_URL=https://api.ashar.finance

# API Key (Bearer token) para autenticacao no Management
ASHAR_API_KEY=seu_api_key_aqui

# URL da API CaaS / Digital Assets (padrao: https://api-assets.ashar.finance)
CAAS_API_URL=https://api-assets.ashar.finance

# Secret HMAC ou Legacy API Key para autenticacao no CaaS
# Se for um secret hex (64 chars), o MCP gera automaticamente uma legacy key assinada
# Se ja estiver no formato header.payload.signature, usa diretamente
CAAS_API_KEY=seu_caas_api_key_aqui

# Transport: "stdio" (local) ou "http" (remoto)
ASHAR_TRANSPORT=stdio

# Porta HTTP (apenas quando ASHAR_TRANSPORT=http)
PORT=3000
