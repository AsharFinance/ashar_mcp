# Ashar MCP Server - Configuracao

# URL da API Ashar (padrao: https://api.ashar.finance)
ASHAR_API_URL=https://api.ashar.finance

# API Key (Bearer token) para autenticacao
ASHAR_API_KEY=seu_api_key_aqui

# Transport: "stdio" (local) ou "http" (remoto)
ASHAR_TRANSPORT=stdio

# Porta HTTP (apenas quando ASHAR_TRANSPORT=http)
PORT=3000
