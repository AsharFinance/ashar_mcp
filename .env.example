# Ashar MCP Server v2 — Configuracao

# ── API Management ──────────────────────────────────────────────────────────

# URL da API Ashar Management (padrao: https://api.ashar.finance)
ASHAR_API_URL=https://api.ashar.finance

# API Key (formato x-api-key) para autenticacao no Management (OBRIGATORIO)
ASHAR_API_KEY=seu_api_key_aqui

# ── CaaS / Digital Assets ───────────────────────────────────────────────────

# URL da API CaaS / Digital Assets (padrao: https://api-assets.up.railway.app)
CAAS_API_URL=https://api-assets.up.railway.app

# Secret HMAC ou Legacy API Key para autenticacao no CaaS
# Se for um secret hex (64 chars), o MCP gera automaticamente uma legacy key assinada
# Se ja estiver no formato header.payload.signature, usa diretamente
CAAS_API_KEY=seu_caas_api_key_aqui

# ── Transport ──────────────────────────────────────────────────────────────

# Transport: "stdio" (local, default) ou "http" (remoto)
ASHAR_TRANSPORT=stdio

# Porta HTTP (apenas quando ASHAR_TRANSPORT=http)
PORT=3000

# ── Debug & Diagnostico ─────────────────────────────────────────────────────

# Ativa logs detalhados de requests/responses
# ASHAR_DEBUG=true

# Pula o health check de inicializacao (util se a API estiver offline)
# ASHAR_SKIP_HEALTH=true

# Timeout de requisicao HTTP em ms (default: 30000)
# ASHAR_TIMEOUT_MS=30000
