{
  "name": "GetV1FiatWithdrawals",
  "description": "Retrieve Fiat Withdrawals (Remittances)",
  "arguments": {
    "type": "object",
    "properties": {
      "api_key": {
        "type": "string",
        "minLength": 32,
        "description": "Ashar API key (Bearer token)"
      },
      "limit": {
        "type": "integer",
        "minimum": 1,
        "maximum": 100,
        "description": "Number of withdrawals to return (default: 30)"
      },
      "offset": {
        "type": "integer",
        "minimum": 0,
        "description": "Pagination offset"
      },
      "status": {
        "type": "string",
        "enum": ["INITIATED", "PENDING_PAYMENT", "PROCESSING", "COMPLETED", "FAILED", "CANCELLED"],
        "description": "Filter by withdrawal status"
      },
      "currency": {
        "type": "string",
        "enum": ["BRL", "USD", "EUR"],
        "description": "Filter by destination currency"
      }
    },
    "required": ["api_key"]
  }
}
