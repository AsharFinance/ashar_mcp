{
  "name": "PostV1CryptoDepositAddresses",
  "description": "Generate Crypto Deposit Address (USDT/USDC)",
  "arguments": {
    "type": "object",
    "properties": {
      "api_key": {
        "type": "string",
        "minLength": 32,
        "description": "Ashar API key (Bearer token)"
      },
      "requestBody": {
        "type": "object",
        "properties": {
          "asset": {
            "type": "string",
            "enum": ["USDT", "USDC"],
            "description": "Asset to receive"
          },
          "chain": {
            "type": "string",
            "enum": ["ETHEREUM", "BSC", "POLYGON", "TRX"],
            "description": "Blockchain network for the deposit"
          }
        },
        "required": ["asset", "chain"],
        "description": "Generates a custody address for receiving USDT or USDC. WARNING: Send ONLY the specified asset on the specified network. Sending the wrong asset or using the wrong network may result in permanent loss of funds. Deposit is credited after blockchain confirmations."
      }
    },
    "required": ["api_key"]
  }
}
