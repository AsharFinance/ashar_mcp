{
  "name": "PostV1CryptoWithdrawals",
  "description": "Create Crypto Withdrawal (USDT/USDC)",
  "arguments": {
    "type": "object",
    "properties": {
      "api_key": {
        "type": "string",
        "minLength": 32,
        "description": "Ashar API key (Bearer token)"
      },
      "requestBody": {
        "type": "object",
        "properties": {
          "asset": {
            "type": "string",
            "enum": ["USDT", "USDC"],
            "description": "Asset to withdraw"
          },
          "chain": {
            "type": "string",
            "enum": ["ETHEREUM", "BSC", "POLYGON", "TRX"],
            "description": "Destination blockchain network"
          },
          "amount": {
            "type": "number",
            "minimum": 0.000001,
            "description": "Amount to withdraw"
          },
          "destination_address": {
            "type": "string",
            "minLength": 26,
            "maxLength": 128,
            "description": "Destination wallet address"
          },
          "external_id": {
            "type": ["string", "null"],
            "minLength": 1,
            "maxLength": 128,
            "description": "Client-supplied idempotency key to prevent duplicate withdrawals"
          }
        },
        "required": ["asset", "chain", "amount", "destination_address"],
        "description": "Creates a USDT or USDC withdrawal to an external wallet. Approval tiers: up to $1,000 = AUTO (immediate); $1,000–$10,000 = SINGLE_ADMIN (1 approval); above $10,000 = MULTI_SIG (2 of 3 admins)."
      }
    },
    "required": ["api_key"]
  }
}
