{
  "name": "PostV1BrlDeposits",
  "description": "Create BRL PIX Deposit",
  "arguments": {
    "type": "object",
    "properties": {
      "api_key": {
        "type": "string",
        "minLength": 32,
        "description": "Ashar API key (Bearer token)"
      },
      "requestBody": {
        "type": "object",
        "properties": {
          "amount": {
            "type": "number",
            "minimum": 0.01,
            "description": "Deposit amount in BRL (e.g. 100.00 = R$100.00)",
            "example": 100.00
          },
          "external_id": {
            "type": ["string", "null"],
            "minLength": 1,
            "maxLength": 128,
            "description": "Client-supplied idempotency key to prevent duplicate deposits"
          }
        },
        "required": ["amount"],
        "description": "Creates a PIX charge for BRL deposit. Returns the PIX QR Code (copy-and-paste string). The user pays the PIX to credit BRL into their Ashar account."
      }
    },
    "required": ["api_key"]
  }
}
