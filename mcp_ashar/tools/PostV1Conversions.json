{
  "name": "PostV1Conversions",
  "description": "Create FIAT_TO_CRYPTO Currency Conversion (BRL → USDT/USDC)",
  "arguments": {
    "type": "object",
    "properties": {
      "api_key": {
        "type": "string",
        "minLength": 32,
        "description": "Ashar API key (Bearer token)"
      },
      "requestBody": {
        "type": "object",
        "properties": {
          "from_currency": {
            "type": "string",
            "enum": ["BRL", "USD", "EUR", "USDT", "USDC"],
            "description": "Source currency"
          },
          "to_currency": {
            "type": "string",
            "enum": ["BRL", "USD", "EUR", "USDT", "USDC"],
            "description": "Destination currency (must differ from from_currency)"
          },
          "amount_from": {
            "type": "number",
            "minimum": 0.01,
            "description": "Amount to convert in the source currency"
          },
          "amount_to_estimate": {
            "type": ["number", "null"],
            "minimum": 0.01,
            "description": "Estimated amount in destination currency (optional)"
          }
        },
        "required": ["from_currency", "to_currency", "amount_from"],
        "description": "Creates a FIAT_TO_CRYPTO virtual swap request (accounting ledger operation). Supports all combinations of BRL, USD, EUR, USDT, and USDC. The conversion stays PENDING until approved by an administrator. NOTE: This tool always uses direction=FIAT_TO_CRYPTO. For CRYPTO_TO_FIAT, call the API directly."
      }
    },
    "required": ["api_key"]
  }
}
