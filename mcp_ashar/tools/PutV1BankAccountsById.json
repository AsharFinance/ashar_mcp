{
  "name": "PutV1BankAccountsById",
  "description": "Update Bank Account",
  "arguments": {
    "type": "object",
    "properties": {
      "api_key": {
        "type": "string",
        "minLength": 32,
        "description": "Ashar API key (Bearer token)"
      },
      "id": {
        "type": "string",
        "minLength": 8,
        "maxLength": 64,
        "description": "ID of the bank account to update"
      },
      "requestBody": {
        "type": "object",
        "properties": {
          "label": {
            "type": "string",
            "maxLength": 128,
            "description": "New display name"
          },
          "beneficiary": {
            "type": "string",
            "maxLength": 128,
            "description": "Updated account holder name"
          },
          "bank_name": {
            "type": "string",
            "maxLength": 128,
            "description": "Updated bank name"
          },
          "account_number": {
            "type": "string",
            "maxLength": 32,
            "description": "Updated account number"
          },
          "swift": {
            "type": "string",
            "minLength": 8,
            "maxLength": 11,
            "description": "Updated SWIFT/BIC code"
          },
          "iban": {
            "type": "string",
            "minLength": 15,
            "maxLength": 34,
            "description": "Updated IBAN"
          },
          "pix_key": {
            "type": "string",
            "maxLength": 128,
            "description": "Updated PIX key"
          },
          "is_favorite": {
            "type": "boolean",
            "description": "Mark as favorite"
          }
        },
        "description": "Updates an existing bank account. Only the fields sent in the request body will be modified; omitted fields remain unchanged."
      }
    },
    "required": ["api_key", "id"]
  }
}
