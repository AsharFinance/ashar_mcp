{
  "name": "GetV1BrlDeposits",
  "description": "Retrieve BRL Deposits",
  "arguments": {
    "type": "object",
    "properties": {
      "api_key": {
        "type": "string",
        "minLength": 1,
        "description": "Ashar API key (Bearer token)"
      },
      "limit": {
        "type": "string",
        "enum": [
          "10",
          "30",
          "50",
          "100"
        ],
        "description": "Number of deposits to return (default: 30)"
      },
      "status": {
        "type": "string",
        "enum": [
          "PENDING",
          "PAID",
          "FAILED",
          "EXPIRED"
        ],
        "description": "Filter by deposit status"
      }
    },
    "required": [
      "api_key"
    ]
  }
}
