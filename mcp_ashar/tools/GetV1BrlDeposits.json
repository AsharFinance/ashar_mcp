{
  "name": "GetV1BrlDeposits",
  "description": "Retrieve BRL Deposits",
  "arguments": {
    "type": "object",
    "properties": {
      "api_key": {
        "type": "string",
        "minLength": 32,
        "description": "Ashar API key (Bearer token)"
      },
      "limit": {
        "type": "integer",
        "minimum": 1,
        "maximum": 100,
        "description": "Number of deposits to return (default: 30)"
      },
      "offset": {
        "type": "integer",
        "minimum": 0,
        "description": "Pagination offset"
      },
      "status": {
        "type": "string",
        "enum": ["PENDING", "PAID", "FAILED", "EXPIRED"],
        "description": "Filter by deposit status"
      }
    },
    "required": ["api_key"]
  }
}
