{
  "name": "GetV1CryptoWithdrawalsByExternalId",
  "description": "Retrieve Crypto Withdrawal Status",
  "arguments": {
    "type": "object",
    "properties": {
      "api_key": {
        "type": "string",
        "minLength": 32,
        "description": "Ashar API key (Bearer token)"
      },
      "external_id": {
        "type": "string",
        "minLength": 1,
        "maxLength": 128,
        "description": "External ID of the withdrawal (returned when the withdrawal is created)"
      }
    },
    "required": ["api_key", "external_id"]
  }
}
